{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collections-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-collections-grid__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 40px;
    font-size: 32px;
    color: {{ block.settings.heading_color }};
  }

  .ai-collections-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-collections-grid__item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-collections-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-collections-grid__link-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .ai-collections-grid__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  {% if block.settings.image_ratio == 'square' %}
    .ai-collections-grid__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 100%;
    }
  {% else %}
    .ai-collections-grid__image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 66.67%;
    }
  {% endif %}

  .ai-collections-grid__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collections-grid__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-collections-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-collections-grid__overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    padding: 20px;
    transition: background 0.3s ease;
  }

  .ai-collections-grid__item-{{ ai_gen_id }}:hover .ai-collections-grid__overlay-{{ ai_gen_id }} {
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85), transparent);
  }

  .ai-collections-grid__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 600;
  }

  .ai-collections-grid__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-collections-grid__empty-state-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    margin-bottom: 20px;
    opacity: 0.3;
  }

  .ai-collections-grid__empty-state-{{ ai_gen_id }} p {
    font-size: 16px;
    margin: 10px 0;
  }

  @media screen and (max-width: 989px) {
    .ai-collections-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-collections-grid__heading-{{ ai_gen_id }} {
      font-size: 28px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collections-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-collections-grid__heading-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 30px;
    }

    .ai-collections-grid__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-collections-grid-{{ ai_gen_id }} {
      padding: 30px 15px;
    }
  }
{% endstyle %}

<collections-grid-{{ ai_gen_id }} class="ai-collections-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-collections-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% if collections.size > 0 %}
    <div class="ai-collections-grid__container-{{ ai_gen_id }}">
      {% for collection in collections %}
        <div class="ai-collections-grid__item-{{ ai_gen_id }}">
          <a href="{{ collection.url }}" class="ai-collections-grid__link-{{ ai_gen_id }}">
            <div class="ai-collections-grid__image-wrapper-{{ ai_gen_id }}">
              {% if collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 800 }}"
                  alt="{{ collection.image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="{% if block.settings.image_ratio == 'square' %}800{% else %}533{% endif %}"
                  class="ai-collections-grid__image-{{ ai_gen_id }}"
                >
              {% elsif collection.products.first and collection.products.first.featured_image %}
                <img
                  src="{{ collection.products.first.featured_image | image_url: width: 800 }}"
                  alt="{{ collection.products.first.featured_image.alt | escape }}"
                  loading="lazy"
                  width="800"
                  height="{% if block.settings.image_ratio == 'square' %}800{% else %}533{% endif %}"
                  class="ai-collections-grid__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-collections-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'collection-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
              <div class="ai-collections-grid__overlay-{{ ai_gen_id }}">
                <h3 class="ai-collections-grid__title-{{ ai_gen_id }}">{{ collection.title }}</h3>
              </div>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-collections-grid__empty-state-{{ ai_gen_id }}">
      {{ 'collection-1' | placeholder_svg_tag }}
      <p>No collections found</p>
      <p>Create your first collection to see it displayed here</p>
    </div>
  {% endif %}
</collections-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeGrid();
      }

      initializeGrid() {
        const items = this.querySelectorAll('.ai-collections-grid__item-{{ ai_gen_id }}');
        items.forEach((item, index) => {
          item.style.animationDelay = `${index * 0.05}s`;
        });
      }
    }

    customElements.define('collections-grid-{{ ai_gen_id }}', CollectionsGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "All collections grid",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Collection cards"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "square",
          "label": "Square"
        },
        {
          "value": "landscape",
          "label": "Landscape"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "All collections grid"
    }
  ]
}
{% endschema %}
