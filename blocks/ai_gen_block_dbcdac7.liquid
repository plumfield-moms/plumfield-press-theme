      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "message_size",
      "label": "Message size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Discount code style"
    },
    {
      "type": "color",
      "id": "code_background_color",
      "label": "Background color",
      "default": "#f9ddab"
    },
    {
      "type": "color",
      "id": "code_border_color",
      "label": "Border color",
      "default": "#77183c"
    },
    {
      "type": "color",
      "id": "code_text_color",
      "label": "Text color",
      "default": "#77183c"
    },
    {
      "type": "range",
      "id": "code_size",
      "label": "Code size",
      "min": 16,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "code_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Background color",
      "default": "#77183c"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#5a1230"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#f9ddab"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
